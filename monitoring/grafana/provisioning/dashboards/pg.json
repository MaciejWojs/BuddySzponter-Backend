{
  "title": "PostgreSQL Overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "tags": ["postgresql", "overview", "pg_stat", "database"],
  "version": 2,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "DB Up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "pg_up", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Connections",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{datname!~\"template0|template1|postgres\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "TPS",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_xact_commit{datname!~\"template0|template1|postgres\"}[1m]) + rate(pg_stat_database_xact_rollback{datname!~\"template0|template1|postgres\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Connections by state",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname!~\"template0|template1|postgres\",state!=\"\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Transactions",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_xact_commit{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "commit",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_database_xact_rollback{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "rollback",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rows operations",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_tup_returned{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "select",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_inserted{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "insert",
          "refId": "B"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_updated{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "update",
          "refId": "C"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_deleted{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "delete",
          "refId": "D"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_blks_hit{datname!~\"template0|template1|postgres\"}[1m])) / (sum(rate(pg_stat_database_blks_hit{datname!~\"template0|template1|postgres\"}[1m])) + sum(rate(pg_stat_database_blks_read{datname!~\"template0|template1|postgres\"}[1m])))",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk IO",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_blks_read{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "read",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_database_blks_hit{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "hit",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Deadlocks",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_deadlocks{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "deadlocks",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Temp Files",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_temp_files{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "files",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_database_temp_bytes{datname!~\"template0|template1|postgres\"}[1m]))",
          "legendFormat": "bytes",
          "refId": "B"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Query Types",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "label_replace(sum(rate(pg_stat_database_tup_returned{datname!~\"template0|template1|postgres\"}[1m])), \"operation\", \"select\", \"\", \"\")",
          "legendFormat": "{{operation}}",
          "refId": "A"
        },
        {
          "expr": "label_replace(sum(rate(pg_stat_database_tup_inserted{datname!~\"template0|template1|postgres\"}[1m])), \"operation\", \"insert\", \"\", \"\")",
          "legendFormat": "{{operation}}",
          "refId": "B"
        },
        {
          "expr": "label_replace(sum(rate(pg_stat_database_tup_updated{datname!~\"template0|template1|postgres\"}[1m])), \"operation\", \"update\", \"\", \"\")",
          "legendFormat": "{{operation}}",
          "refId": "C"
        },
        {
          "expr": "label_replace(sum(rate(pg_stat_database_tup_deleted{datname!~\"template0|template1|postgres\"}[1m])), \"operation\", \"delete\", \"\", \"\")",
          "legendFormat": "{{operation}}",
          "refId": "D"
        }
      ]
    }
  ]
}
