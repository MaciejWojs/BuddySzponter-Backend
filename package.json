{
  "name": "buddy-szponter-backend",
  "private": true,
  "version": "1.0.0",
  "lint-staged": {
    "*.ts": "prettier --write",
    "*.tsx": "prettier --write",
    "*.js": "prettier --write",
    "*.jsx": "prettier --write",
    "package.json": "prettier --write"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "minify": "bun run typecheck && bun build src/index.ts --target bun --outdir .dist --minify --sourcemap",
    "prod": "bun run --bun .dist/index.js",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bunx --bun tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "migrate": "bun --bun drizzle-kit migrate",
    "generate": "bun --bun drizzle-kit generate",
    "push": "bun --bun drizzle-kit push",
    "seed": "bun run --bun src/infrastucture/db/seed.ts"
  },
  "dependencies": {
    "@socket.io/bun-engine": "^0.1.0",
    "email-validator": "^2.0.4",
    "drizzle-kit": "1.0.0-beta.12-5845444",
    "drizzle-orm": "1.0.0-beta.12-5845444",
    "hono": "^4.12.5",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@0xts/gitleaks-cli": "^0.1.3",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "@types/socket.io": "^3.0.2",
    "@types/zxcvbn": "^4.4.5",
    "drizzle-seed": "1.0.0-beta.12-5845444",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-embed": "^0.5.1",
    "prettier-plugin-sql": "^0.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
