{
  "name": "buddy-szponter-backend",
  "private": true,
  "version": "1.0.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "package.json": "prettier --write"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "minify": "bun run typecheck && bun build src/index.ts --target bun --outdir .dist --minify --sourcemap",
    "prod": "bun run --bun .dist/index.js",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bunx --bun tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "migrate": "bun --bun drizzle-kit migrate",
    "generate": "bun --bun drizzle-kit generate",
    "push": "bun --bun drizzle-kit push",
    "reset": "bun run --bun src/infrastucture/db/reset-db.ts",
    "seed": "bun run --bun src/infrastucture/db/seed.ts"
  },
  "dependencies": {
    "@hono/prometheus": "^1.0.2",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.10.6",
    "@socket.io/bun-engine": "^0.1.0",
    "drizzle-kit": "1.0.0-beta.20",
    "drizzle-orm": "1.0.0-beta.20",
    "email-validator": "^2.0.4",
    "hono": "^4.12.10",
    "http-status-codes": "^2.3.0",
    "imgkit": "^2.2.1",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "zod": "^4.3.6",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@0xts/gitleaks-cli": "^0.1.3",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/format": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.11",
    "@types/socket.io": "^3.0.2",
    "@types/zxcvbn": "^4.4.5",
    "drizzle-seed": "1.0.0-beta.20",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-embed": "^0.5.1",
    "prettier-plugin-sql": "^0.20.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
