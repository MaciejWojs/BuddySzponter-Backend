# Environment variables for Buddy Szponter backend application

# PEPPER and SALT for USER authentication
PEPPER=ExamplePepper
SALT=ExampleSalt

# Set to true to enable development mode, which may include features 
DEVELOPMENT=true

# Should the payloads be encrypted before sending to the client? Set to true to enable encryption.
# Note: If you change this, make sure to update the client-side code to match the encryption settings.
# Note: This also affects the websocket client
PAYLOAD_ENCRYPTED=true

# Database connection string for PostgreSQL
DATABASE_URL="postgresql://ExampleUser:ExamplePassword@localhost:5432/example_db"

POSTGRES_USER=ExampleUser
POSTGRES_PASSWORD=ExamplePassword
POSTGRES_DB=example_db

# Redis/Valkey configuration

VALKEY_PASSWORD=ExampleValkeyPassword
VALKEY_USER=ExampleValkeyUser

# MinIO configuration for object storage

MINIO_ROOT_USER=ExampleMinioAdmin
MINIO_ROOT_PASSWORD=ExampleMinioPassword

PHOTO_QUEUE_NAME=example_photo_processing_queue

# JWT secrets for authentication

JWT_ACCESS_SECRET=ExampleJWTAccessSecret
JWT_REFRESH_SECRET=ExampleJWTRefreshSecret

# Additional environment variables for Docker Compose
COMPOSE_BAKE=1
MONITORING_ENABLED=true